# 环境变量 - 包含敏感 API Keys，绝对不能提交
.env
.env.local
.env.*.local
.env.production
.dev.vars

# Next.js
.next/
out/
build/

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Cloudflare
.wrangler/
wrangler.toml.bak

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Testing
coverage/
.nyc_output/

# Misc
*.log
.cache/
